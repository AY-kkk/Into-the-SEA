# ─────────────────────────────────────────────────────────────
# 上岸小助手 · Into the SEA — 环境变量示例
# 复制为 .env / .env.local 后填写。切勿提交真实密钥。
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME="上岸小助手"
NODE_ENV="development"

# Database (PostgreSQL: 本地 docker / Supabase / Neon)
# MVP 可先留空，使用 seed/mock；接入真实库时设置 DATA_SOURCE=db 并填写 DATABASE_URL。
# 数据读取来源：seed（默认，读 data/seed/*.json）| db（读 PostgreSQL）
DATA_SOURCE="seed"
# 本地 docker（见 docker-compose.yml）：
DATABASE_URL="postgresql://into_the_sea:into_the_sea@localhost:5432/into_the_sea?schema=public"
# Supabase 示例：postgresql://postgres:[PWD]@db.[REF].supabase.co:5432/postgres
# Neon 示例：postgresql://[USER]:[PWD]@[HOST].neon.tech/[DB]?sslmode=require

# ── Provider 选择开关（默认 mock，可切换为真实实现）──
# 可选值：mock | real
EXAM_INFO_PROVIDER="mock"
LLM_PROVIDER="mock"
SEARCH_PROVIDER="mock"
QUESTION_SEARCH_PROVIDER="mock"

# ── LLM Provider（OpenAI-compatible / 火山方舟 Ark）──
LLM_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
LLM_API_KEY=""
LLM_MODEL="ep-your-endpoint-id"

# 备用 OpenAI-compatible
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# ── Search Provider（Bing / SerpAPI / Tavily / Firecrawl / Exa）──
SEARCH_API_KEY=""
SEARCH_ENDPOINT=""

# ── Redis（可选，用于缓存/会话）──
REDIS_URL=""

# ── 鉴权 / 会话 ──
# 会话 cookie 的 HMAC 签名密钥；生产必须设置（>=16 位，建议 32+）。缺省仅用于开发降级。
AUTH_SECRET=""
# 会话有效期（天）
SESSION_TTL_DAYS="30"

# ── 观测性 ──
# 配置后错误将转发（TODO: 接入 @sentry/nextjs）
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
LOG_LEVEL="info"

# ── API 安全 / 成本护栏 ──
RATE_LIMIT_MAX="60"
RATE_LIMIT_WINDOW_MS="60000"
# LLM 单次请求 max_tokens 上限
LLM_MAX_TOKENS_CAP="1024"
# 单用户每日 LLM 调用次数上限（成本护栏）
LLM_DAILY_CALL_CAP="80"

# ── 定时任务（Vercel Cron） ──
# /api/cron/ingest 的鉴权密钥；生产建议设置，Cron 请求会带 Authorization: Bearer $CRON_SECRET
CRON_SECRET=""

# ── SEO ──
# 站点公开 URL（用于 metadataBase / sitemap / OpenGraph），例如 https://into-the-sea.vercel.app
NEXT_PUBLIC_APP_URL=""

# ── 商业化成本模型（可选，用于成本估算/定价） ──
COST_AVG_TOKENS_PER_CALL="1400"
COST_PRICE_PER_1K_TOKENS="0.004"
