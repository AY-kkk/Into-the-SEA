# ─────────────────────────────────────────────────────────────
# 上岸小助手 · Into the SEA — 环境变量示例
# 复制为 .env / .env.local 后填写。切勿提交真实密钥。
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME="上岸小助手"
NODE_ENV="development"

# Database (PostgreSQL: Supabase / Neon)
# MVP 可先留空，使用 mock provider；接入真实库时填写。
DATABASE_URL="postgresql://user:password@localhost:5432/into_the_sea?schema=public"

# ── Provider 选择开关（默认 mock，可切换为真实实现）──
# 可选值：mock | real
EXAM_INFO_PROVIDER="mock"
LLM_PROVIDER="mock"
SEARCH_PROVIDER="mock"
QUESTION_SEARCH_PROVIDER="mock"

# ── LLM Provider（OpenAI-compatible / 火山方舟 Ark）──
LLM_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
LLM_API_KEY=""
LLM_MODEL="ep-your-endpoint-id"

# 备用 OpenAI-compatible
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# ── Search Provider（Bing / SerpAPI / Tavily / Firecrawl / Exa）──
SEARCH_API_KEY=""
SEARCH_ENDPOINT=""

# ── Redis（可选，用于缓存/会话）──
REDIS_URL=""
